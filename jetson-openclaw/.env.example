# OpenClaw + Ollama environment for Jetson Orin Nano 8GB
# Copy to ~/.openclaw/.env and fill in secrets:
#   cp jetson-openclaw/.env.example ~/.openclaw/.env
#   chmod 600 ~/.openclaw/.env

# --- Ollama (local, no real key needed) ---
OLLAMA_API_KEY=ollama-local
OLLAMA_HOST=127.0.0.1:11434
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1
OLLAMA_KEEP_ALIVE=5m

# --- OpenClaw Gateway ---
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_32
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=lan

# --- Jetson RAM optimization ---
NODE_COMPILE_CACHE=/var/tmp/openclaw-compile-cache
OPENCLAW_NO_RESPAWN=1
NODE_OPTIONS=--max-old-space-size=384

# --- Optional cloud providers (leave unset if using Ollama only) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# --- OpenTelemetry (optional monitoring) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_SERVICE_NAME=openclaw-gateway-jetson
